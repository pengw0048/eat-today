{
  "name": "eat-today",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "node --check src/worker.js && node --check public/app.js",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply eat-today-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply eat-today-db --remote"
  },
  "devDependencies": {
    "wrangler": "^4.107.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true,
    "sharp@0.34.5": true,
    "workerd@1.20260701.1": true
  }
}
